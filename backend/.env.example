# =====================================================================
# Mandarin Master Backend — 环境变量示例
# 复制为 .env 后填入真实密钥
# =====================================================================

# ── 服务端口 ───────────────────────────────────────────────────────────
PORT=3001

# ── PostgreSQL（v0.1.0 起；docker compose up -d 启动本地容器）───────────
DATABASE_URL=postgresql://admin:password123@localhost:5433/mandarin_master

# ── Azure 翻译 + 拼音转写（搜索路由用）─────────────────────────────────
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=canadacentral

# ── Azure 语音 TTS（/api/tts 用）──────────────────────────────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=canadacentral

# ── 管理员密钥（拼音修正功能 PATCH /api/word/:word/pinyin 用）───────────
ADMIN_SECRET=

# ── Auth.js（v0.1.0 起；用户系统启用时填）─────────────────────────────
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# ── DeepSeek（课后总结生成用，Sprint 3 起需要）─────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Stripe（充值用，Sprint 2 起需要）──────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── AI 同学引擎密钥（Sprint 3 起按需启用）─────────────────────────────
# 林小雨 — 火山引擎豆包实时语音
DOUBAO_API_KEY=
DOUBAO_APP_ID=
# 山田凉 — 阶跃星辰 Step-1o-Audio
STEP_API_KEY=
# 辛格 — 阿里 Qwen-Omni-Realtime
DASHSCOPE_API_KEY=
# 艾米丽 — OpenAI gpt-realtime
OPENAI_API_KEY=
# 小智 — 智谱 GLM-4-Voice 自托管
GLM_BASE_URL=
GLM_API_KEY=
